# Futu OpenD Configuration
FUTU_HOST=127.0.0.1
FUTU_PORT=11111

# Feature Switches
# Active trading tools (place/modify/cancel order, order/deal query, etc.)
FUTU_ENABLE_TRADING=0
# Position tools (get_positions/get_position_list)
FUTU_ENABLE_POSITIONS=1

# Trading Environment Configuration
FUTU_TRADE_ENV=SIMULATE
FUTU_SECURITY_FIRM=FUTUSECURITIES
FUTU_TRD_MARKET=HK

# Logging Configuration (MCP Compatible)
# Set to '1' to enable debug mode with stderr logging (NOT recommended for MCP clients)
FUTU_DEBUG_MODE=0

# MCP Mode (automatically set by the server, do not modify)
# MCP_MODE=1

# Note: In MCP mode, all logs go to files only to avoid polluting stdout
# stdout is reserved exclusively for MCP JSON communication
# Log files are stored in the 'logs/' directory
